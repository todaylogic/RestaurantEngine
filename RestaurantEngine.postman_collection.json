{
  "info": {
    "name": "RestaurantEngine API",
    "description": "Complete test suite for RestaurantEngine REST API.\n\n**Setup:**\n1. Run the app: `DB_USERNAME=admin DB_PASSWORD=admin JWT_SECRET=RestaurantEngineSecretKey2026ForJWTSigning!! mvn spring-boot:run`\n2. Register the first admin via POST /api/auth/register\n3. Login via POST /api/auth/login — the token is auto-saved to `{{token}}`\n4. Run other requests in order\n\n**Variables:** `baseUrl` = http://localhost:8080, `token` is set automatically after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "categoryId", "value": "1", "type": "string" },
    { "key": "menuItemId", "value": "1", "type": "string" },
    { "key": "tableId", "value": "1", "type": "string" },
    { "key": "orderId", "value": "1", "type": "string" },
    { "key": "orderItemId", "value": "1", "type": "string" },
    { "key": "staffId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register First Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"admin@restaurant.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\",\n  \"phone\": \"+1-555-0100\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register succeeds', () => pm.response.to.have.status(200));",
                  "pm.test('No password in response', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.not.have.property('password');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restaurant.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.data && body.data.token) {",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "  console.log('Token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Staff (ADMIN-only after first admin exists)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane@restaurant.com\",\n  \"password\": \"staff123\",\n  \"role\": \"STAFF\",\n  \"phone\": \"+1-555-0101\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Second register requires auth', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register without auth (should 401 after first admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Hacker\",\n  \"lastName\": \"Attack\",\n  \"email\": \"hacker@evil.com\",\n  \"password\": \"bad\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthenticated register rejected', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login with wrong password (should 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restaurant.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Wrong password rejected', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
