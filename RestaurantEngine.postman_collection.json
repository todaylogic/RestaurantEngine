      "item": [
        {
          "name": "Get All Staff (MANAGER+)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/staff", "host": ["{{baseUrl}}"], "path": ["api", "staff"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get staff succeeds', () => pm.response.to.have.status(200));",
                  "pm.test('No passwords in list', () => {",
                  "  const list = pm.response.json().data;",
                  "  list.forEach(s => pm.expect(s).to.not.have.property('password'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Staff by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/staff/{{staffId}}", "host": ["{{baseUrl}}"], "path": ["api", "staff", "{{staffId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get staff by id succeeds', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Staff (ADMIN only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Bob\",\n  \"lastName\": \"Jones\",\n  \"email\": \"bob@restaurant.com\",\n  \"password\": \"bob123\",\n  \"role\": \"MANAGER\",\n  \"phone\": \"+1-555-0102\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/staff", "host": ["{{baseUrl}}"], "path": ["api", "staff"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create staff succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.data && body.data.id) pm.collectionVariables.set('staffId', body.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Staff (change phone, no password change)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Bob\",\n  \"lastName\": \"Jones\",\n  \"email\": \"bob@restaurant.com\",\n  \"role\": \"MANAGER\",\n  \"phone\": \"+1-555-9999\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/staff/{{staffId}}", "host": ["{{baseUrl}}"], "path": ["api", "staff", "{{staffId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Update staff succeeds', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Staff (ADMIN only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/staff/{{staffId}}", "host": ["{{baseUrl}}"], "path": ["api", "staff", "{{staffId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delete staff succeeds', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "7. Error Cases",
      "item": [
        {
          "name": "Access protected endpoint without token (should 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tables", "host": ["{{baseUrl}}"], "path": ["api", "tables"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthenticated request rejected', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "STAFF tries to create table (should 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tableNumber\": \"T99\",\n  \"capacity\": 2\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tables", "host": ["{{baseUrl}}"], "path": ["api", "tables"] }
          },
          "_description": "Change the token to a STAFF-role token to test 403. With ADMIN token this will create the table (200)."
        },
        {
          "name": "Get Non-existent Order (should 404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/99999", "host": ["{{baseUrl}}"], "path": ["api", "orders", "99999"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Not found returns 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Item without name (should 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 10.00,\n  \"categoryId\": {{categoryId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/menu/items", "host": ["{{baseUrl}}"], "path": ["api", "menu", "items"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing name rejected with 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
